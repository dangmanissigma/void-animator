-- ── Add Item ─────────────────────────────────────────────────
-- Select an object in the Explorer, pick a joint in the hierarchy, press +Item.
-- The object is parented into the rig model and a new Motor6D is created from
-- the active joint's Part1 to the object's root part.
function UIBuilder:doAddItem()
	if not self.rigCtrl.model then
		self:setStatus("Load a rig first", false); return
	end
	local sel = self.selection:Get()
	if #sel == 0 then
		self:setStatus("Select object(s) in Explorer, then press +Item", false); return
	end
	local activeName = self.rigCtrl.active
	if not activeName then
		self:setStatus("Select a joint to attach to first", false); return
	end
	local info = self.rigCtrl.joints[activeName]
	if not info or not info.part1 then
		self:setStatus("Active joint has no Part1", false); return
	end
	local attachTo = info.part1
	local added = 0

	for _, obj in ipairs(sel) do
		if obj == self.rigCtrl.model then continue end
		local part = nil
		if obj:IsA("BasePart") then
			part = obj
		elseif obj:IsA("Model") then
			part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
		end
		if not part then continue end
		if part:IsDescendantOf(self.rigCtrl.model) then
			self:setStatus(obj.Name .. " already in rig", false); continue
		end

		obj.Parent = self.rigCtrl.model

		local m = Instance.new("Motor6D")
		m.Name  = obj.Name .. "_joint"
		m.Part0 = attachTo
		m.Part1 = part
		m.C0    = attachTo.CFrame:Inverse() * part.CFrame  -- align to current world position
		m.C1    = CFrame.new()
		m.Parent = attachTo
		added = added + 1
	end

	if added == 0 then return end

	self:setStatus("Added " .. added .. " item(s) → " .. activeName, true)

	task.defer(function()
		local model = self.rigCtrl.model
		local n = self.rigCtrl:load(model)
		if n > 0 then
			self.vpCtrl:build(self.rigCtrl)
			self:_insertRestPoseKeys()
			self:updateHierarchy(); self:buildAllTracks(); self:updateProperties()
			self:_setupAutoKey(); self:_updateVpHeader()
		end
	end)
end

-- ── Global input ──────────────────────────────────────────────
function UIBuilder:_registerInput()
	local UIS = self.UIS

	self:_conn(UIS.InputChanged, function(inp)
		if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
		local pos = Vector2.new(inp.Position.X, inp.Position.Y)

		if self.rotDrag.active then
			local rd = self.rotDrag
			local delta = (pos.X - rd.startX) * 0.5
			local ndx = rd.dx + (rd.axis=="X" and delta or 0)
			local ndy = rd.dy + (rd.axis=="Y" and delta or 0)
			local ndz = rd.dz + (rd.axis=="Z" and delta or 0)
			local newCF = self.rigCtrl:buildC0(rd.name, ndx, ndy, ndz)
			-- _suppressAutoKey=true was set on drag start so this applyC0 won't
			-- double-fire the auto-key watcher
			self.rigCtrl:applyC0(rd.name, newCF, self.vpCtrl.cloneMap)
			-- Explicitly write keyframe at the captured drag time
			self.animCtrl:set(rd.name, rd.dragT, newCF)
			self:updateProperties(); self:_redrawKeyframes(); self:updateHierarchy()
		end

		if self.camDrag.active and self.camDrag.startPos and self.vpCtrl.camera then
			local cam = self.vpCtrl.camera
			local d = pos - self.camDrag.startPos
			local center = Vector3.new(0,2,0)
			if self.vpCtrl.clone then
				local ok2, cf2 = pcall(function() return self.vpCtrl.clone:GetBoundingBox() end)
				if ok2 and cf2 then center = cf2.Position end
			end
			local fc = self.camDrag.startCF.Position - center
			local yaw   = CFrame.fromAxisAngle(Vector3.new(0,1,0), math.rad(-d.X*0.4))
			local pitch = CFrame.Angles(math.rad(-d.Y*0.4),0,0)
			cam.CFrame = CFrame.new(center + (yaw*(pitch*CFrame.new(fc))).Position, center)
		end
	end)

	self:_conn(UIS.InputEnded, function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			if self.rotDrag.active then
				local rd = self.rotDrag
				local finalCF = self.rigCtrl:getC0(rd.name)
				if rd.prevCF and not finalCF:FuzzyEq(rd.prevCF, 0.0001) then
					local cn, ct, prev = rd.name, rd.dragT, rd.prevCF
					self.cmdStack:push({
						exec=function()
							self.rigCtrl:applyC0(cn,finalCF,self.vpCtrl.cloneMap)
							self.animCtrl:set(cn,ct,finalCF)
							self:_redrawKeyframes(); self:updateHierarchy(); self:updateProperties()
						end,
						undo=function()
							self.rigCtrl:applyC0(cn,prev,self.vpCtrl.cloneMap)
							self.animCtrl:set(cn,ct,prev)
							self:_redrawKeyframes(); self:updateHierarchy(); self:updateProperties()
						end,
					})
				end
				self.rotDrag = { active=false }
				-- FIX: Re-enable auto-key after drag ends (was disabled in InputBegan)
				self._suppressAutoKey = self.state.playing
				self:updateProperties()
			end
		end
		if inp.UserInputType == Enum.UserInputType.MouseButton3 then
			self.camDrag = { active=false }
		end
	end)

	self:_conn(UIS.InputBegan, function(inp, gpe)
		if gpe then return end
		if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
		local ctrl = UIS:IsKeyDown(Enum.KeyCode.LeftControl) or UIS:IsKeyDown(Enum.KeyCode.RightControl)
		local kc = inp.KeyCode

		if ctrl and kc==Enum.KeyCode.Z then self:doUndo()
		elseif ctrl and kc==Enum.KeyCode.Y then self:doRedo()
		elseif ctrl and kc==Enum.KeyCode.C then
			local nm = self.rigCtrl.active
			if nm then self.tlCtrl.clipboard = { name=nm, cf=self.rigCtrl:getC0(nm) } end
		elseif ctrl and kc==Enum.KeyCode.V then
			local cb = self.tlCtrl.clipboard
			if cb and self.rigCtrl.active then
				self:_applyAndKey(self.rigCtrl.active, 0,0,0, cb.cf)
			end
		elseif kc==Enum.KeyCode.Space then
			if self.state.playing then self.cbStop() else self.cbStart() end
		elseif kc==Enum.KeyCode.Delete or kc==Enum.KeyCode.Backspace then
			local toRemove = {}
			for key in pairs(self.tlCtrl.selected) do
				local sep = key:find("|")
				if sep then
					local sn = key:sub(1,sep-1); local ki = tonumber(key:sub(sep+1))
					local tr = self.animCtrl.keyframes[sn]
					if tr and ki and tr[ki] then
						table.insert(toRemove, { name=sn, t=tr[ki].t, cf=tr[ki].cf })
					end
				end
			end
			for _, r in ipairs(toRemove) do
				local rn,rt,rc = r.name, r.t, r.cf
				local cmd = {
					exec=function() self.animCtrl:remove(rn,rt); self:_redrawKeyframes(); self:updateHierarchy() end,
					undo=function() self.animCtrl:set(rn,rt,rc); self:_redrawKeyframes(); self:updateHierarchy() end,
				}
				cmd.exec(); self.cmdStack:push(cmd)
			end
			self.tlCtrl:clearSelection()
		end
	end)

	-- Click in Studio scene to select joint by part
	self:_conn(UIS.InputBegan, function(inp, gpe)
		if gpe then return end
		if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
		if not self.rigCtrl.model then return end
		local mouse = self.plugin:GetMouse()
		local target = mouse.Target; if not target then return end
		local jn = self.rigCtrl:jointForPart(target)
		if not jn then
			local cur = target.Parent; local depth = 0
			while cur and depth < 6 do
				if cur:IsA("BasePart") then jn = self.rigCtrl:jointForPart(cur); if jn then break end end
				cur = cur.Parent; depth = depth + 1
			end
		end
		if jn then
			self.rigCtrl:setActive(jn)
			self:updateHierarchy(); self:updateProperties(); self:_refreshTrackHL(); self:_highlightActivePart()
			self:setStatus("Selected: "..jn, true)
		end
	end)
end

return UIBuilder